          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const fs=require('fs');const log={timestamp:new Date().toISOString(),hook:'PreToolUse',tool:'Write',input:JSON.parse(process.env.TOOL_INPUT||'{}')};const f='C:/Users/vmuser/Desktop/Rag-converseation-model/.claude/logs/tool_calls.jsonl';fs.appendFileSync(f,JSON.stringify(log)+'\\n');\" 2>/dev/null || true"
          }
        ]
