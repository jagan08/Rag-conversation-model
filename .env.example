# ─── LLM Providers ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ─── Retrieval ────────────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...

# ─── Database ────────────────────────────────────────────────────────────────
DB_URL=sqlite:///aria.db

# ─── Model Overrides (optional) ──────────────────────────────────────────────
ARIA_ORCHESTRATOR_MODEL=claude-opus-4-5
ARIA_SPECIALIST_MODEL=claude-sonnet-4-5
ARIA_CRITIC_MODEL=gpt-4o
ARIA_LIGHTWEIGHT_MODEL=gpt-4o-mini
ARIA_FALLBACK_MODEL=gpt-4o
ARIA_PROVIDER=litellm
